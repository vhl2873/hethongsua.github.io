# Copy this file to .env and fill real values.
# Never commit .env because it contains private keys.

# Supabase values safe for browser/client usage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Supabase server-only value. Do not expose this in frontend HTML/JS.
SUPABASE_SECRET_KEY=your-supabase-secret-or-service-role-key

# Supabase Storage bucket used for product/news images
SUPABASE_STORAGE_BUCKET=products

# Compatibility aliases used by some frontend/backend code
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-or-service-role-key
